---
import * as stylex from "@stylexjs/stylex";

import { OWNER_NAME } from "../consts";
import { styles } from "./Footer.stylex";
import SocialLinks from "./SocialLinks.astro";

const year = new Date().getFullYear();
const copyRightText = `${year} ${OWNER_NAME}. All rights reserved.`;
const version = import.meta.env.PUBLIC_VERSION ?? "development";
---

<footer {...stylex.attrs(styles.footer)}>
  {version} &copy; {copyRightText}
  <SocialLinks linkColor="gray" />
</footer>
